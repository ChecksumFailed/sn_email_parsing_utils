        <sys_updated_on>2026-04-17 18:36:46</sys_updated_on>
        <value>(function(outputs, steps, params, stepResult, assertEqual) {
  // Happy path: plain text key:value pairs
  var actionName = 'global.parse_namevalue_pairs';
  var textInput = 'Name: John Smith' + '\n' + 'Department: IT' + '\n' + 'Location: Building A';
  var inputs = { string_to_parse: textInput };
  var result = sn_fd.FlowAPI.getRunner().action(actionName).inForeground().withInputs(inputs).run();
  var actionOutputs = result.getOutputs();
  var nvp = actionOutputs['name_value_pairs'];
  if (!nvp) { stepResult.setFailed('FAIL: name_value_pairs output was null'); return; }
  var parsed = (typeof nvp === 'string') ? JSON.parse(nvp) : nvp;
  if (parsed['Name'] !== 'John Smith') { stepResult.setFailed('FAIL: Name expected "John Smith", got: ' + parsed['Name']); return; }
  if (parsed['Department'] !== 'IT') { stepResult.setFailed('FAIL: Department expected "IT", got: ' + parsed['Department']); return; }
  if (parsed['Location'] !== 'Building A') { stepResult.setFailed('FAIL: Location expected "Building A", got: ' + parsed['Location']); return; }
  stepResult.setSuccess();
  stepResult.setOutputMessage('PASS: Plain text NVP parsed correctly. Result: ' + JSON.stringify(parsed));
})(outputs, steps, params, stepResult, assertEqual);</value>
