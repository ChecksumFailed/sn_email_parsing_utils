        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = '&lt;p&gt;AT&amp;amp;T &amp;lt;rocks&amp;gt; &amp;quot;quoted&amp;quot;&lt;/p&gt;';
    var result = parser.HTMLtoText(input);

    if (result.indexOf('AT&amp;T') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "AT&amp;T" (decoded &amp;amp;). Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('&lt;rocks&gt;') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "&lt;rocks&gt;" (decoded &amp;lt; &amp;gt;). Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('"quoted"') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "quoted" with literal quotes (decoded &amp;quot;). Got: ' + result);
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: All HTML entities decoded correctly. Output: ' + result);
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
