        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    // NOTE: gs.nil('') returns true in ServiceNow, so extractKeyValuePairs('') throws.
    // This test documents that behavior: empty string is treated as nil by gs.nil().
    var parser = new CF_EmailParsingUtils();
    var threw = false;
    try {
        parser.extractKeyValuePairs('');
    } catch(e) {
        threw = true;
    }
    if (!threw) {
        stepResult.setOutputMessage('FAIL: Expected extractKeyValuePairs("") to throw (gs.nil("") is true in ServiceNow), but no error was thrown');
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: extractKeyValuePairs("") correctly throws (gs.nil("") === true in ServiceNow)');
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
