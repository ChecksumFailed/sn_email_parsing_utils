        <sys_updated_on>2026-04-15 22:22:15</sys_updated_on>
        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = '&lt;html&gt;&lt;head&gt;&lt;style&gt;body{font-family:Arial}&lt;/style&gt;&lt;/head&gt;&lt;body&gt;' +
                '&lt;div&gt;Request Details&lt;/div&gt;' +
                '&lt;div&gt;Requested By: John Smith&lt;/div&gt;&lt;br&gt;' +
                '&lt;div&gt;Priority: High&lt;/div&gt;' +
                '&lt;p&gt;Please process &amp;amp; review ASAP.&lt;/p&gt;' +
                '&lt;/body&gt;&lt;/html&gt;';

    var result = parser.HTMLtoText(input);

    if (result.indexOf('Request Details') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "Request Details" in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('John Smith') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "John Smith" in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('review ASAP') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "review ASAP" in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (/&lt;[^&gt;]+&gt;/.test(result)) {
        stepResult.setOutputMessage('FAIL: HTML tags still present in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('font-family') !== -1) {
        stepResult.setOutputMessage('FAIL: Style content still present. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Realistic email HTML converted to clean plain text. Output: ' + result);
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
