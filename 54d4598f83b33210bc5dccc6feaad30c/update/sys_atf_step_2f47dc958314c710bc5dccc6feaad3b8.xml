        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = '&lt;style&gt;body { color: red; font-size: 12px; }&lt;/style&gt;&lt;p&gt;Content here&lt;/p&gt;';
    var result = parser.HTMLtoText(input);

    if (result.indexOf('Content here') === -1) {
        stepResult.setOutputMessage('FAIL: Expected "Content here" in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    if (result.indexOf('color: red') !== -1 || result.indexOf('font-size') !== -1) {
        stepResult.setOutputMessage('FAIL: Style block content still present in output. Got: ' + result);
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Style block stripped correctly. Output: ' + result);
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
