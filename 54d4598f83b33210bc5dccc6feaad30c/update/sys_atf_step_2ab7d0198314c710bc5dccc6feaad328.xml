        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = 'Subject: Laptop Request\nPriority: High\nRequestedBy: Jane Doe';
    var result = parser.parseNameValuePairs(input);
    if (typeof result !== 'object' || result === null) {
        stepResult.setOutputMessage('FAIL: Expected object result. Got: ' + typeof result);
        stepResult.setFailed();
        return;
    }
    if (result['Subject'] !== 'Laptop Request') {
        stepResult.setOutputMessage('FAIL: Expected result["Subject"] === "Laptop Request". Got: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    if (result['Priority'] !== 'High') {
        stepResult.setOutputMessage('FAIL: Expected result["Priority"] === "High". Got: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    if (result['RequestedBy'] !== 'Jane Doe') {
        stepResult.setOutputMessage('FAIL: Expected result["RequestedBy"] === "Jane Doe". Got: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Plain text parsed correctly. Result: ' + JSON.stringify(result));
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
