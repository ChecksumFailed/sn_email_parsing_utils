        <value>(function(outputs, steps, params, stepResult, assertEqual) {
  // Multi-pair plain text: 4 key:value pairs
  var actionName = 'global.parse_namevalue_pairs';
  var textInput = 'Priority: High' + '\n' + 'Category: Software' + '\n' + 'Impact: 2' + '\n' + 'Urgency: 2';
  var inputs = { string_to_parse: textInput };
  var result = sn_fd.FlowAPI.getRunner().action(actionName).inForeground().withInputs(inputs).run();
  var actionOutputs = result.getOutputs();
  var nvp = actionOutputs['name_value_pairs'];
  if (!nvp) { stepResult.setFailed('FAIL: name_value_pairs output was null'); return; }
  var parsed = (typeof nvp === 'string') ? JSON.parse(nvp) : nvp;
  var keys = Object.keys(parsed);
  if (keys.length !== 4) { stepResult.setFailed('FAIL: Expected 4 pairs, got ' + keys.length + '. Result: ' + JSON.stringify(parsed)); return; }
  if (parsed['Priority'] !== 'High') { stepResult.setFailed('FAIL: Priority expected "High", got: ' + parsed['Priority']); return; }
  if (parsed['Category'] !== 'Software') { stepResult.setFailed('FAIL: Category expected "Software", got: ' + parsed['Category']); return; }
  if (parsed['Impact'] !== '2') { stepResult.setFailed('FAIL: Impact expected "2", got: ' + parsed['Impact']); return; }
  if (parsed['Urgency'] !== '2') { stepResult.setFailed('FAIL: Urgency expected "2", got: ' + parsed['Urgency']); return; }
  stepResult.setSuccess();
  stepResult.setOutputMessage('PASS: Multi-pair plain text parsed correctly. Keys: ' + keys.join(', '));
})(outputs, steps, params, stepResult, assertEqual);</value>
