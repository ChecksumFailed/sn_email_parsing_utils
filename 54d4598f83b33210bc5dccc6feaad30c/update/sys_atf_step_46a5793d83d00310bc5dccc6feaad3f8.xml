        <value>(function(outputs, steps, params, stepResult, assertEqual) {
  // Two tables in one HTML, multiple rows each
  var actionName = 'global.parse_html_table';
  var html = '&lt;table&gt;&lt;tr&gt;&lt;th&gt;Item&lt;/th&gt;&lt;th&gt;Price&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Laptop&lt;/td&gt;&lt;td&gt;1200&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Monitor&lt;/td&gt;&lt;td&gt;400&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;' +
             '&lt;table&gt;&lt;tr&gt;&lt;th&gt;Key&lt;/th&gt;&lt;th&gt;Value&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Status&lt;/td&gt;&lt;td&gt;Active&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;';
  var inputs = { html: html };
  var result = sn_fd.FlowAPI.getRunner().action(actionName).inForeground().withInputs(inputs).run();
  var actionOutputs = result.getOutputs();
  var tableJson = actionOutputs['table_json'];
  if (!tableJson) { stepResult.setFailed('FAIL: table_json output was null'); return; }
  var parsed = (typeof tableJson === 'string') ? JSON.parse(tableJson) : tableJson;
  if (!Array.isArray(parsed) || parsed.length !== 3) { stepResult.setFailed('FAIL: Expected 3 rows total (2+1), got ' + parsed.length + ': ' + JSON.stringify(parsed)); return; }
  if (parsed[0]['Item'] !== 'Laptop') { stepResult.setFailed('FAIL: Row 0 Item expected "Laptop", got: ' + parsed[0]['Item']); return; }
  if (parsed[2]['Key'] !== 'Status') { stepResult.setFailed('FAIL: Row 2 Key expected "Status", got: ' + parsed[2]['Key']); return; }
  stepResult.setSuccess();
  stepResult.setOutputMessage('PASS: Two-table HTML parsed correctly (3 rows). Result: ' + JSON.stringify(parsed));
})(outputs, steps, params, stepResult, assertEqual);</value>
