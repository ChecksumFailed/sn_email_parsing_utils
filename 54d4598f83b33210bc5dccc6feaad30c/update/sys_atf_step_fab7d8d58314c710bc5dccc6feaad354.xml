        <sys_updated_on>2026-04-15 22:24:05</sys_updated_on>
        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = '&lt;html&gt;&lt;body&gt;' +
                '&lt;div&gt;Ticket: INC0009999&lt;/div&gt;' +
                '&lt;div&gt;Requester: Alice Johnson&lt;/div&gt;' +
                '&lt;div&gt;Department: Finance&lt;/div&gt;' +
                '&lt;div&gt;Category: Hardware&lt;/div&gt;' +
                '&lt;/body&gt;&lt;/html&gt;';
    var result = parser.parseNameValuePairs(input);
    var expected = { 'Ticket': 'INC0009999', 'Requester': 'Alice Johnson', 'Department': 'Finance', 'Category': 'Hardware' };
    var keys = Object.keys(expected);
    for (var i = 0; i &lt; keys.length; i++) {
        var key = keys[i];
        if (result[key] !== expected[key]) {
            stepResult.setOutputMessage('FAIL: Expected result["' + key + '"] === "' + expected[key] + '". Got: ' + result[key] + '. Full result: ' + JSON.stringify(result));
            stepResult.setFailed();
            return;
        }
    }
    stepResult.setOutputMessage('PASS: All 4 pairs extracted from HTML email body. Result: ' + JSON.stringify(result));
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
