        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = 'Priority :   High  \nStatus :   Open  ';
    var result = parser.extractKeyValuePairs(input);
    if (result['Priority'] !== 'High') {
        stepResult.setOutputMessage('FAIL: Expected result["Priority"] === "High" (trimmed). Got: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    if (result['Status'] !== 'Open') {
        stepResult.setOutputMessage('FAIL: Expected result["Status"] === "Open" (trimmed). Got: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Whitespace trimmed correctly. Result: ' + JSON.stringify(result));
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
