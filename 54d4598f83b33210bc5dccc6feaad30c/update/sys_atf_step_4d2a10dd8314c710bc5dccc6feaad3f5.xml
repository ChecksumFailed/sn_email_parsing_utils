        <sys_updated_on>2026-04-15 22:34:37</sys_updated_on>
        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var input = '&lt;table&gt;&lt;tr&gt;&lt;td&gt;Field&lt;/td&gt;&lt;td&gt;Value&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Priority&lt;/td&gt;&lt;td&gt;High&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;' +
                '&lt;table&gt;&lt;tr&gt;&lt;td&gt;Key&lt;/td&gt;&lt;td&gt;Data&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Category&lt;/td&gt;&lt;td&gt;Hardware&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;';
    var result = parser.parseHtmlTables(input);
    if (!Array.isArray(result)) {
        stepResult.setOutputMessage('FAIL: Expected Array result. Got: ' + typeof result);
        stepResult.setFailed();
        return;
    }
    if (result.length !== 2) {
        stepResult.setOutputMessage('FAIL: Expected 2 rows total (1 from each table). Got: ' + result.length + '. Result: ' + JSON.stringify(result));
        stepResult.setFailed();
        return;
    }
    if (result[0]['Field'] !== 'Priority') {
        stepResult.setOutputMessage('FAIL: Expected result[0]["Field"] === "Priority". Got: ' + JSON.stringify(result[0]));
        stepResult.setFailed();
        return;
    }
    if (result[1]['Key'] !== 'Category') {
        stepResult.setOutputMessage('FAIL: Expected result[1]["Key"] === "Category". Got: ' + JSON.stringify(result[1]));
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Two tables combined correctly. Result: ' + JSON.stringify(result));
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
