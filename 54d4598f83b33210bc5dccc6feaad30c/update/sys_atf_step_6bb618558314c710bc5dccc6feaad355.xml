        <sys_updated_on>2026-04-15 22:19:46</sys_updated_on>
        <value>(function(outputs, steps, params, stepResult, assertEqual) {

    var parser = new CF_EmailParsingUtils();

    // 1. HTML string → true
    var result1 = parser.isHTML('&lt;p&gt;Hello&lt;/p&gt;');
    if (result1 !== true) {
        stepResult.setOutputMessage('FAIL: isHTML("&lt;p&gt;Hello&lt;/p&gt;") expected true, got ' + result1);
        stepResult.setFailed();
        return;
    }

    // 2. Plain text → false
    var result2 = parser.isHTML('plain text with no tags');
    if (result2 !== false) {
        stepResult.setOutputMessage('FAIL: isHTML("plain text") expected false, got ' + result2);
        stepResult.setFailed();
        return;
    }

    // 3. Empty string → false
    var result3 = parser.isHTML('');
    if (result3 !== false) {
        stepResult.setOutputMessage('FAIL: isHTML("") expected false, got ' + result3);
        stepResult.setFailed();
        return;
    }

    // 4. No argument (uses default '') → false
    var result4 = parser.isHTML();
    if (result4 !== false) {
        stepResult.setOutputMessage('FAIL: isHTML() (no arg) expected false, got ' + result4);
        stepResult.setFailed();
        return;
    }

    // 5. Unclosed angle bracket (not a valid tag) → false
    var result5 = parser.isHTML('&lt;not a tag');
    if (result5 !== false) {
        stepResult.setOutputMessage('FAIL: isHTML("&lt;not a tag") expected false (no closing &gt;), got ' + result5);
        stepResult.setFailed();
        return;
    }

    stepResult.setOutputMessage('PASS: All isHTML assertions passed (5/5)');
    stepResult.setSuccess();

})(outputs, steps, params, stepResult, assertEqual);</value>
