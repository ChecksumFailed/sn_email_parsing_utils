        <value>(function(outputs, steps, params, stepResult, assertEqual) {
    var parser = new CF_EmailParsingUtils();
    var result = parser.parseHtmlTables('&lt;table&gt;&lt;/table&gt;');
    if (!Array.isArray(result)) {
        stepResult.setOutputMessage('FAIL: Expected Array result. Got: ' + typeof result);
        stepResult.setFailed();
        return;
    }
    if (result.length !== 0) {
        stepResult.setOutputMessage('FAIL: Expected empty array for empty table. Got length: ' + result.length);
        stepResult.setFailed();
        return;
    }
    stepResult.setOutputMessage('PASS: Empty table correctly returned empty array');
    stepResult.setSuccess();
})(outputs, steps, params, stepResult, assertEqual);</value>
